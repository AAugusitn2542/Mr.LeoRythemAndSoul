<!DOCTYPE html>
<html lang="en">
<head>
  <title>MrLeoRythmAndSoul - Gallery</title>
  <link rel="stylesheet" href="/style.css">
  <link rel="stylesheet" href="/gallery.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <script src="/scripts/header.js" defer></script>
</head>
<body>
  <header></header>

  <section class="gallery-section">
    <div class="gallery-hero">
      <div class="gallery-hero-content">
        <p class="gallery-hero-label">📸 Behind The Scenes</p>
        <h1>Gallery</h1>
        <p class="gallery-hero-sub">Moments from the stage, the studio, and everything in between.</p>
      </div>
    </div>

    <div class="gallery-controls">
      <div class="gallery-filter-btns">
        <button class="gallery-filter active" data-year="all">All</button>
        <button class="gallery-filter" data-year="2026">2026</button>
        <button class="gallery-filter" data-year="2025">2025</button>
      </div>
      <div class="gallery-count">
        <span id="photoCount"><%= gallery.length %></span> photos
      </div>
    </div>

    <div class="gallery-grid">
      <% gallery.sort((a, b) => new Date(b.date) - new Date(a.date)).forEach(photo => { %>
        <% const year = new Date(photo.date).getFullYear(); %>
        <% const monthLabel = new Date(photo.date).toLocaleDateString('en-US', { month: 'short', year: 'numeric' }); %>
        <div class="gallery-item" data-year="<%= year %>" onclick="openLightbox('<%= photo.photo %>', '<%= photo.event %>', '<%= photo.location %>', '<%= monthLabel %>')">
          <img src="<%= photo.photo %>" alt="<%= photo.event %>" loading="lazy">
          <div class="gallery-overlay">
            <p class="overlay-event"><%= photo.event %></p>
            <% if (photo.location) { %>
              <p class="overlay-location">📍 <%= photo.location %></p>
            <% } %>
            <p class="overlay-date"><%= monthLabel %></p>
          </div>
        </div>
      <% }); %>
    </div>
  </section>

  <!-- Lightbox -->
  <div id="lightbox" class="lightbox" onclick="closeLightbox()">
    <div class="lightbox-content" onclick="event.stopPropagation()">
      <button class="lightbox-close" onclick="closeLightbox()">✕</button>
      <img id="lightboxImg" src="" alt="">
      <div class="lightbox-info">
        <p id="lightboxEvent"></p>
        <p id="lightboxLocation"></p>
        <p id="lightboxDate"></p>
      </div>
    </div>
  </div>

  <script>
    // Filter by year
    document.querySelectorAll('.gallery-filter').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.gallery-filter').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');

        const year = btn.dataset.year;
        let visible = 0;
        document.querySelectorAll('.gallery-item').forEach(item => {
          const show = year === 'all' || item.dataset.year === year;
          item.style.display = show ? 'block' : 'none';
          if (show) visible++;
        });
        document.getElementById('photoCount').textContent = visible;
      });
    });

    // Lightbox
    function openLightbox(src, event, location, date) {
      document.getElementById('lightboxImg').src = src;
      document.getElementById('lightboxEvent').textContent = event;
      document.getElementById('lightboxLocation').textContent = location ? '📍 ' + location : '';
      document.getElementById('lightboxDate').textContent = date;
      document.getElementById('lightbox').style.display = 'flex';
      document.body.style.overflow = 'hidden';
    }

    function closeLightbox() {
      document.getElementById('lightbox').style.display = 'none';
      document.body.style.overflow = '';
    }

    document.addEventListener('keydown', e => {
      if (e.key === 'Escape') closeLightbox();
    });
  </script>
</body>
</html>
