<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Mr. Leo Rhythm & Soul Band — Experience unforgettable live soul, R&B, and funk performances in the Bay Area. Book us for your next event.">
    <meta property="og:title" content="Mr. Leo Rhythm & Soul Band">
    <meta property="og:description" content="Live soul, R&B, and funk. Unforgettable performances in the Bay Area.">
    <title>Mr. Leo Rhythm & Soul Band</title>
    <link rel="stylesheet" href="/style.css">
    <link rel="stylesheet" href="/gallery.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="/scripts/transitions.js"></script>
    <script src="/scripts/header.js" defer></script>
    <script src="/scripts/footer.js" defer></script>
</head>
<body>
  <header></header>

  <!-- Hero Section -->
  <section class="hero">
    <div class="hero-content">
      <h1>Mr Leo Rhythm <br/> & Soul Band</h1>
      <p class="hero-tagline">Experience unforgettable live performances that blend classic soul, R&B, and funk. We bring energy, passion, and authenticity to every stage.</p>
      <div class="hero-buttons">
        <a href="/Performance" class="btn btn-primary">🎵 Listen Now</a>
        <a href="/Tour" class="btn btn-secondary">📅 Tour Dates</a>
      </div>
    </div>
    <div class="hero-image">
      <img src="/images/hero_pic.png" alt="Mr Leo Rhythm & Soul Band" />
    </div>

    <!-- Scroll Indicator -->
    <div class="scroll-indicator" id="scrollIndicator">
      <span>Scroll</span>
      <div class="scroll-arrow">&#8595;</div>
    </div>
  </section>

  <script>
    // Fade out scroll indicator when user scrolls
    window.addEventListener('scroll', () => {
      const indicator = document.getElementById('scrollIndicator');
      if (window.scrollY > 300) {
        indicator.style.opacity = '0';
      } else {
        indicator.style.opacity = '1';
      }
    });
  </script>

  <!-- Next Show Spotlight -->
  <%
    const nextShow = tours
      .filter(t => new Date(t.dateMonth + ' ' + t.dateDay + ', ' + t.dateYear) >= new Date())
      .sort((a, b) => new Date(a.dateMonth + ' ' + a.dateDay + ', ' + a.dateYear) - new Date(b.dateMonth + ' ' + b.dateDay + ', ' + b.dateYear))[0];
  %>
  <% if (nextShow) { %>
  <section class="next-show-section">
    <div class="next-show-label">🎤 Next Show</div>
    <div class="next-show-content">
      <div class="next-show-info">
        <h2 class="next-show-venue"><%= nextShow.venue %></h2>
        <p class="next-show-location">📍 <%= nextShow.city %>, <%= nextShow.state %></p>
        <p class="next-show-date">📅 <%= nextShow.fullDate %> &nbsp;|&nbsp; 🕐 Doors open at <%= nextShow.doorsOpenTime %></p>
        <p class="next-show-price"><%= nextShow.priceRange === 'Free Admission' ? '🎟️ Free Admission' : '🎟️ ' + nextShow.priceRange %></p>
        <div class="next-show-buttons">
          <a href="https://www.google.com/maps/search/?api=1&query=<%= encodeURIComponent(nextShow.venue + ' ' + nextShow.city + ', ' + nextShow.state) %>" target="_blank" class="btn btn-primary">📍 Get Directions</a>
          <a href="/Tour" class="btn btn-secondary">View All Shows</a>
        </div>
      </div>

      <div class="countdown-box">
        <div class="countdown-title">Starts In</div>
        <div class="countdown-timer">
          <div class="countdown-unit">
            <span id="cd-days">00</span>
            <label>Days</label>
          </div>
          <div class="countdown-sep">:</div>
          <div class="countdown-unit">
            <span id="cd-hours">00</span>
            <label>Hrs</label>
          </div>
          <div class="countdown-sep">:</div>
          <div class="countdown-unit">
            <span id="cd-mins">00</span>
            <label>Mins</label>
          </div>
          <div class="countdown-sep">:</div>
          <div class="countdown-unit">
            <span id="cd-secs">00</span>
            <label>Secs</label>
          </div>
        </div>
      </div>
    </div>

    <% if (nextShow.image) { %>
    <div class="next-show-flyer">
      <img src="<%= nextShow.image %>" alt="<%= nextShow.venue %> Flyer">
    </div>
    <% } %>

  </section>

  <script>
    (function() {
      const target = new Date('<%= nextShow.dateMonth %> <%= nextShow.dateDay %>, <%= nextShow.dateYear %>');
      function update() {
        const now = new Date();
        const diff = target - now;
        if (diff <= 0) {
          document.querySelector('.countdown-title').textContent = 'Happening Now!';
          return;
        }
        const days  = Math.floor(diff / (1000 * 60 * 60 * 24));
        const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
        const mins  = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
        const secs  = Math.floor((diff % (1000 * 60)) / 1000);
        document.getElementById('cd-days').textContent  = String(days).padStart(2, '0');
        document.getElementById('cd-hours').textContent = String(hours).padStart(2, '0');
        document.getElementById('cd-mins').textContent  = String(mins).padStart(2, '0');
        document.getElementById('cd-secs').textContent  = String(secs).padStart(2, '0');
      }
      update();
      setInterval(update, 1000);
    })();
  </script>
  <% } %>

  <!-- Tour Dates Section -->
  <section class="tour-section">
    <div class="tour-hero">
      <div class="tour-hero-content">
        <p class="tour-hero-label">📅 On Tour</p>
        <h1>Tour Dates</h1>
        <p class="tour-hero-sub">Join us live! Experience the energy, the music, and the magic. Find a show near you.</p>
      </div>
    </div>

    <div class="tour-stats">
      <div class="stat">
        <div class="stat-number"><%= tours.filter(t => new Date(t.dateMonth + ' ' + t.dateDay + ', ' + t.dateYear) >= new Date()).length %></div>
        <div class="stat-label">Upcoming Shows</div>
      </div>
      <div class="stat">
        <div class="stat-number"><%= tours.filter(t => t.priceRange === 'Free Admission').length %></div>
        <div class="stat-label">Free Events</div>
      </div>
      <div class="stat">
        <div class="stat-number"><%= tours.filter(t => t.status === 'Sold Out').length %></div>
        <div class="stat-label">Sold Out</div>
      </div>
    </div>

    <div class="tour-controls">
      <div class="search-box">
        <input type="text" id="tourSearch" placeholder="Search by city, venue, or state..." class="search-input">
      </div>
      <div class="filter-dropdown">
        <button class="filter-btn">All Shows ▼</button>
        <div class="dropdown-menu" id="filterMenu">
          <div class="filter-option" data-filter="all">All Shows</div>
          <div class="filter-option" data-filter="on-sale">On Sale</div>
          <div class="filter-option" data-filter="limited">Limited Tickets</div>
          <div class="filter-option" data-filter="sold-out">Sold Out</div>
          <div class="filter-option" data-filter="tba">TBA</div>
        </div>
      </div>
    </div>

    <div class="tour-list">
      <% tours.forEach((tour, index) => { %>
        <div class="tour-card" data-status="<%= tour.status.toLowerCase().replace(' ', '-') %>" data-date="<%= tour.dateMonth %> <%= tour.dateDay %>, <%= tour.dateYear %>">
          <div class="tour-date-box">
            <div class="date-month"><%= tour.dateMonth %></div>
            <div class="date-day"><%= tour.dateDay %></div>
            <div class="date-year"><%= tour.dateYear %></div>
          </div>

          <div class="tour-info">
            <h3 class="venue-name"><%= tour.venue %></h3>
            <p class="venue-location">📍 <%= tour.city %>, <%= tour.state %></p>

            <% if (tour.eventType) { %>
              <p class="event-type">⭐ <%= tour.eventType %></p>
            <% } %>

            <% if (tour.dayOfWeek) { %>
              <p class="day-of-week">📅 <%= tour.dayOfWeek %></p>
            <% } %>

            <p class="capacity-price">
              <span>👥 <%= tour.capacity %></span>
              <span>💵 <%= tour.priceRange %></span>
            </p>
          </div>

          <div class="tour-status-badge" data-badge-color="<%= tour.badgeColor %>">
            <%= tour.status %>
          </div>

          <div class="tour-details-link">Click for details →</div>
        </div>

        <!-- Modal for tour details -->
        <div class="event-modal" id="home-modal-<%= index %>">
          <div class="modal-content">
            <span class="modal-close" data-index="<%= index %>">✕</span>

            <div class="modal-image">
              <img src="<%= tour.image %>" alt="<%= tour.venue %>">
            </div>

            <div class="modal-body">
              <h2><%= tour.venue %></h2>
              <p class="modal-location">📍 <%= tour.city %>, <%= tour.state %></p>

              <div class="modal-details">
                <div class="detail-group">
                  <h4>Date & Time</h4>
                  <p><%= tour.fullDate %></p>
                  <p class="doors-time">Doors open at <%= tour.doorsOpenTime %></p>
                </div>

                <div class="detail-group">
                  <h4>Status</h4>
                  <p><span class="status-badge" data-badge-color="<%= tour.badgeColor %>" style="color: white; padding: 4px 12px; border-radius: 20px; display: inline-block;"><%= tour.status %></span></p>
                </div>

                <div class="detail-group">
                  <h4>Venue Capacity</h4>
                  <p>👥 <%= tour.capacity %> people</p>
                </div>

                <div class="detail-group">
                  <h4>Ticket Price</h4>
                  <p><%= tour.priceRange %></p>
                </div>
              </div>

              <div class="modal-buttons">
                <button class="buy-tickets-btn">🎫 Buy Tickets</button>
                <a
                  href="https://www.google.com/maps/search/?api=1&query=<%= encodeURIComponent(tour.venue + ' ' + tour.city + ', ' + tour.state) %>"
                  target="_blank"
                  class="view-map-btn"
                >
                  📍 View on Map
                </a>
                <button class="share-btn">↗️</button>
              </div>

              <div class="modal-info">
                <p><strong>Age Restriction:</strong> <%= tour.ageRestriction %></p>
                <p><strong>Parking:</strong> <%= tour.parking %></p>
                <p><strong>Support Acts:</strong> <%= tour.supportActs %></p>
              </div>
            </div>
          </div>
        </div>
      <% }); %>
    </div>
  </section>

  <script>
    document.querySelectorAll('[data-badge-color]').forEach(el => {
      const color = el.getAttribute('data-badge-color');
      if (color) el.style.backgroundColor = color;
    });

    function openModal(index) {
      document.getElementById('home-modal-' + index).style.display = 'flex';
      document.body.style.overflow = 'hidden';
    }

    function closeModal(index) {
      document.getElementById('home-modal-' + index).style.display = 'none';
      document.body.style.overflow = '';
    }

    document.querySelectorAll('.modal-close').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        const idx = btn.getAttribute('data-index');
        if (idx !== null) closeModal(idx);
      });
    });

    // Mark past events as greyed out
    const today = new Date();
    today.setHours(0, 0, 0, 0);
    document.querySelectorAll('.tour-card').forEach((card, index) => {
      const eventDate = new Date(card.getAttribute('data-date'));
      if (!isNaN(eventDate) && eventDate < today) {
        card.classList.add('past-event');
      }
      card.addEventListener('click', () => openModal(index));
    });

    // Scroll reveal — each card fades in with a staggered delay
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const card = entry.target;
          const index = [...document.querySelectorAll('.tour-card')].indexOf(card);
          setTimeout(() => card.classList.add('revealed'), index * 100);
          observer.unobserve(card);
        }
      });
    }, { threshold: 0.15 });

    document.querySelectorAll('.tour-card').forEach(card => observer.observe(card));

    document.querySelectorAll('.event-modal').forEach(modal => {
      modal.addEventListener('click', (e) => {
        if (e.target === modal) modal.style.display = 'none';
      });
    });

    document.getElementById('tourSearch').addEventListener('keyup', (e) => {
      const searchTerm = e.target.value.toLowerCase();
      document.querySelectorAll('.tour-card').forEach(card => {
        const text = card.textContent.toLowerCase();
        card.style.display = text.includes(searchTerm) ? 'flex' : 'none';
      });
    });

    document.querySelectorAll('.filter-option').forEach(option => {
      option.addEventListener('click', () => {
        const filter = option.dataset.filter;
        document.querySelectorAll('.tour-card').forEach(card => {
          if (filter === 'all') {
            card.style.display = 'flex';
          } else {
            card.style.display = card.dataset.status === filter ? 'flex' : 'none';
          }
        });
      });
    });
  </script>
</body>
</html>
