<!DOCTYPE html>
<html lang="en">
<head>
  <title>Nichelle Jackson — Booking Manager</title>
  <link rel="stylesheet" href="/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <script src="/scripts/header.js" defer></script>
  <style>
    .profile-page {
      background: linear-gradient(135deg, #0a0010 0%, #1a0033 50%, #0a0010 100%);
      min-height: 100vh;
      padding-bottom: 80px;
    }

    /* Hero Banner */
    .profile-hero {
      background:
        linear-gradient(135deg, rgba(0,0,0,0.85) 0%, rgba(30,0,60,0.75) 100%),
        url('/images/gallerypic08.png') center top / cover no-repeat;
      height: 280px;
      position: relative;
      width: 100%;
      box-sizing: border-box;
    }

    .profile-hero::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      height: 3px;
      background: linear-gradient(90deg, transparent, #b366ff, transparent);
    }

    /* Profile Card */
    .profile-card {
      max-width: 1000px;
      margin: -80px auto 0;
      padding: 0 30px;
      position: relative;
      z-index: 2;
    }

    .profile-top {
      display: flex;
      align-items: center;
      gap: 35px;
      margin-bottom: 40px;
    }

    .profile-photo-wrap {
      flex-shrink: 0;
      position: relative;
    }

    .profile-photo {
      width: 160px;
      height: 160px;
      border-radius: 50%;
      object-fit: cover;
      object-position: center top;
      border: 5px solid #b366ff;
      box-shadow: 0 0 40px rgba(179, 102, 255, 0.4);
    }

    .profile-badge {
      position: absolute;
      bottom: 6px;
      right: 6px;
      background: #b366ff;
      color: white;
      font-size: 0.65rem;
      font-weight: 700;
      letter-spacing: 1px;
      padding: 4px 8px;
      border-radius: 20px;
      text-transform: uppercase;
      white-space: nowrap;
    }

    .profile-identity {
      padding-bottom: 10px;
    }

    .profile-identity h1 {
      font-size: 2.4rem;
      font-weight: 900;
      color: white;
      margin: 0 0 6px 0;
      letter-spacing: 1px;
    }

    .profile-title {
      font-size: 1rem;
      color: #b366ff;
      font-weight: 600;
      letter-spacing: 3px;
      text-transform: uppercase;
      margin: 0 0 10px 0;
    }

    .profile-since {
      font-size: 0.85rem;
      color: rgba(255,255,255,0.5);
      margin: 0;
    }

    /* Main Grid */
    .profile-grid {
      display: grid;
      grid-template-columns: 2fr 1fr;
      gap: 25px;
    }

    .profile-section {
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(179,102,255,0.15);
      border-radius: 14px;
      padding: 32px;
      margin-bottom: 25px;
    }

    .profile-section h2 {
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: #b366ff;
      margin: 0 0 18px 0;
    }

    .profile-section p {
      color: rgba(255,255,255,0.8);
      line-height: 1.85;
      font-size: 0.97rem;
      margin: 0;
    }

    /* Expertise Tags */
    .expertise-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
    }

    .expertise-tag {
      background: rgba(179,102,255,0.12);
      border: 1px solid rgba(179,102,255,0.35);
      color: #d4a5ff;
      padding: 7px 16px;
      border-radius: 20px;
      font-size: 0.85rem;
      font-weight: 500;
    }

    /* Contact Card */
    .contact-card .contact-row {
      display: flex;
      align-items: center;
      gap: 14px;
      padding: 14px 0;
      border-bottom: 1px solid rgba(255,255,255,0.06);
    }

    .contact-card .contact-row:last-of-type {
      border-bottom: none;
    }

    .contact-icon {
      width: 38px;
      height: 38px;
      background: rgba(179,102,255,0.15);
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 0.95rem;
      color: #b366ff;
      flex-shrink: 0;
    }

    .contact-label {
      font-size: 0.75rem;
      color: rgba(255,255,255,0.4);
      text-transform: uppercase;
      letter-spacing: 1px;
      margin: 0 0 2px 0;
    }

    .contact-value {
      color: white;
      font-size: 0.9rem;
      font-weight: 500;
      margin: 0;
      text-decoration: none;
      transition: color 0.2s;
    }

    .contact-value:hover {
      color: #b366ff;
    }

    /* Stats Row */
    .stats-row {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 15px;
      margin-bottom: 25px;
    }

    .stat-box {
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(179,102,255,0.15);
      border-radius: 12px;
      padding: 22px;
      text-align: center;
    }

    .stat-box .stat-num {
      font-size: 2rem;
      font-weight: 900;
      color: #b366ff;
      display: block;
      line-height: 1;
      margin-bottom: 6px;
    }

    .stat-box .stat-lbl {
      font-size: 0.78rem;
      color: rgba(255,255,255,0.5);
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    /* CTA */
    .profile-cta {
      display: block;
      width: 100%;
      text-align: center;
      background: linear-gradient(135deg, #b366ff, #7c3aff);
      color: white;
      padding: 16px;
      border-radius: 10px;
      font-weight: 700;
      font-size: 1rem;
      text-decoration: none;
      margin-top: 20px;
      letter-spacing: 1px;
      transition: all 0.3s ease;
      box-shadow: 0 6px 20px rgba(179,102,255,0.3);
    }

    .profile-cta:hover {
      transform: translateY(-3px);
      box-shadow: 0 10px 30px rgba(179,102,255,0.5);
      -webkit-text-fill-color: white;
    }

    .back-link {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      color: rgba(255,255,255,0.5);
      font-size: 0.85rem;
      text-decoration: none;
      margin: 20px 0 20px 0;
      transition: color 0.2s;
    }

    .back-link:hover {
      color: #b366ff;
      -webkit-text-fill-color: #b366ff;
    }

    @media (max-width: 768px) {
      .profile-grid { grid-template-columns: 1fr; }
      .profile-top { flex-direction: column; align-items: center; text-align: center; }
      .stats-row { grid-template-columns: repeat(3, 1fr); }
      .profile-identity h1 { font-size: 1.8rem; }
    }
  </style>
</head>
<body>
  <header></header>

  <div class="profile-page">
    <div class="profile-hero"></div>

    <div class="profile-card">
      <a href="/theCrew" class="back-link">← Back to The Crew</a>

      <div class="profile-top">
        <div class="profile-photo-wrap">
          <img src="<%= manager.photo %>" alt="<%= manager.name %>" class="profile-photo">
          <span class="profile-badge">Management</span>
        </div>
        <div class="profile-identity">
          <h1><%= manager.name %></h1>
          <p class="profile-title"><%= manager.title %></p>
          <p class="profile-since">With the band since <%= manager.joinYear %></p>
        </div>
      </div>

      <!-- Stats -->
      <div class="stats-row">
        <div class="stat-box">
          <span class="stat-num"><%= new Date().getFullYear() - manager.joinYear %>+</span>
          <span class="stat-lbl">Years with Band</span>
        </div>
        <div class="stat-box">
          <span class="stat-num">100+</span>
          <span class="stat-lbl">Shows Booked</span>
        </div>
        <div class="stat-box">
          <span class="stat-num">50+</span>
          <span class="stat-lbl">Venues Secured</span>
        </div>
      </div>

      <div class="profile-grid">
        <!-- Left Column -->
        <div>
          <div class="profile-section">
            <h2>About</h2>
            <p><%= manager.bio %></p>
          </div>

          <div class="profile-section">
            <h2>Areas of Expertise</h2>
            <div class="expertise-tags">
              <% manager.expertise.forEach(skill => { %>
                <span class="expertise-tag"><%= skill %></span>
              <% }); %>
            </div>
          </div>
        </div>

        <!-- Right Column -->
        <div>
          <div class="profile-section contact-card">
            <h2>Contact</h2>

            <div class="contact-row">
              <div class="contact-icon">📧</div>
              <div>
                <p class="contact-label">Email</p>
                <a href="mailto:<%= manager.email %>" class="contact-value"><%= manager.email %></a>
              </div>
            </div>

            <div class="contact-row">
              <div class="contact-icon">📍</div>
              <div>
                <p class="contact-label">Based In</p>
                <p class="contact-value">Bay Area, CA</p>
              </div>
            </div>

            <div class="contact-row">
              <div class="contact-icon">🕐</div>
              <div>
                <p class="contact-label">Response Time</p>
                <p class="contact-value">Within 24–48 hrs</p>
              </div>
            </div>

            <a href="/contact" class="profile-cta">🎤 Book The Band</a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <footer></footer>
</body>
</html>
